{
  "name": "agentic-sdlc-pipeline",
  "version": "0.1.0",
  "description": "A multi-agent system that automates the software development lifecycle — from a feature spec (and optional Figma design tokens) to planned, generated, tested, reviewed, and deploy-gated code.",
  "type": "module",
  "bin": {
    "asdlc": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ai-agents",
    "agentic",
    "sdlc",
    "llm",
    "anthropic",
    "claude",
    "code-generation",
    "react-native"
  ],
  "author": "Harpalsinh Jadav <harpalsinh.jadav99@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
