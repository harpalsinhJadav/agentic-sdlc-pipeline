# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (defaults to claude-opus-4-8)
# ASDLC_MODEL=claude-opus-4-8

# Optional: token budget for a full pipeline run (default 200000).
# The orchestrator tracks cumulative usage and aborts gracefully if exceeded.
# ASDLC_TOKEN_BUDGET=200000
