# Choose your provider: anthropic | openai | gemini (default: anthropic)
# ASDLC_PROVIDER=anthropic

# Provide the key for whichever provider you use. Only the selected provider's
# key is required. (The web UI takes the key per-run instead — see README.)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Optional: override the default model. Defaults per provider:
#   anthropic → claude-opus-4-8   openai → gpt-4o   gemini → gemini-1.5-pro
# ASDLC_MODEL=

# Optional: token budget for a full pipeline run (default 200000).
# The orchestrator tracks cumulative usage and aborts gracefully if exceeded.
# ASDLC_TOKEN_BUDGET=200000

# Optional: port for the web server (default 3001).
# PORT=3001
